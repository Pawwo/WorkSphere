# LLM — OpenAI-compatible endpoint (llama-server, Ollama, vLLM, OpenRouter, …)
# Optimized for Bielik GGUF via llama.cpp; any /v1/chat/completions server works.
LLM_BASE_URL=http://127.0.0.1:8006/v1
LLM_MODEL=minitron-Bielik-7B-v3.0-Instruct-GGUF.Q4_K_M.gguf
LLM_MODEL_FILE=minitron-Bielik-7B-v3.0-Instruct-GGUF.Q4_K_M.gguf
LLM_API_KEY=unused
LLM_MAX_TOKENS=8192
LLM_CONTEXT_SIZE=8192
LLM_TEMPERATURE=0.1
# Optional: wake script before scrape/apply (custom GPU idle manager)
LLM_WAKE_URL=
LLM_WAKE_ENABLED=false
LLM_WAKE_TIMEOUT_SECONDS=90

# WebSearch — SearXNG (install.sh or deploy/searxng/setup.sh)
SEARXNG_BASE_URL=http://127.0.0.1:8888
SEARXNG_LANGUAGE=pl

# Runtime paths
DATA_DIR=./data
BUN_PATH=
REPO_ROOT=.

# CV output: html (Playwright PDF, recommended) or latex (legacy)
CV_RENDERER=html

# API server
HOST=0.0.0.0
PORT=8080

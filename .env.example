# LLM — llama-server on local GPU (see config.yaml for model/base_url)
LLM_BASE_URL=http://127.0.0.1:8006/v1
LLM_MODEL=minitron-Bielik-7B-v3.0-Instruct-GGUF.Q4_K_M.gguf
LLM_MODEL_FILE=minitron-Bielik-7B-v3.0-Instruct-GGUF.Q4_K_M.gguf
LLM_API_KEY=unused
LLM_MAX_TOKENS=8192
LLM_CONTEXT_SIZE=8192
LLM_TEMPERATURE=0.1
# local-llm-llm-manager — wake GPU + llama-server before scrape/apply
LLM_WAKE_URL=http://127.0.0.1:8099
LLM_WAKE_ENABLED=true
LLM_WAKE_TIMEOUT_SECONDS=90

# WebSearch — SearXNG
SEARXNG_BASE_URL=http://127.0.0.1:8888
SEARXNG_LANGUAGE=pl

# Runtime paths
DATA_DIR=./data
BUN_PATH=/home/pawel/.bun/bin/bun
REPO_ROOT=.

# LaTeX (TinyTeX) — auto ~/.TinyTeX; install: bash scripts/install_latex.sh
# LATEX_BIN_DIR=$HOME/.TinyTeX/bin/x86_64-linux

# API server
HOST=0.0.0.0
PORT=8080

# LLM — llama-server on BC-250
LLM_BASE_URL=http://192.168.0.112:8006/v1
LLM_MODEL=minitron-Bielik-7B-v3.0-Instruct-GGUF.Q4_K_M.gguf
LLM_MODEL_FILE=minitron-Bielik-7B-v3.0-Instruct-GGUF.Q4_K_M.gguf
LLM_API_KEY=unused
LLM_MAX_TOKENS=512
LLM_CONTEXT_SIZE=4096
LLM_TEMPERATURE=0.1
LLM_WAKE_URL=http://192.168.0.112:8099
LLM_WAKE_ENABLED=true
LLM_WAKE_TIMEOUT_SECONDS=90

# WebSearch — SearXNG on this Pi
SEARXNG_BASE_URL=http://192.168.0.194:8888
SEARXNG_LANGUAGE=pl

# Runtime paths
DATA_DIR=./data
REPO_ROOT=.
BUN_PATH=/home/admin/.bun/bin/bun

# PDF — system Chromium (no playwright install)
CV_RENDERER=html
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium

# API server
HOST=0.0.0.0
PORT=8080

# Post-batch (Pi has no job_finder SSH target)
POST_BATCH_PI_COMPARE=0

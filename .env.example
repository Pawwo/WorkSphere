# LLM — OpenAI-compatible endpoint (llama-server, Ollama, vLLM, OpenRouter, …)
LLM_BASE_URL=http://127.0.0.1:8006/v1
LLM_MODEL=your-model-name
LLM_MODEL_FILE=your-model-name
# Example Polish model: minitron-Bielik-7B-v3.0-Instruct-GGUF.Q4_K_M.gguf
LLM_API_KEY=unused
LLM_MAX_TOKENS=8192
LLM_CONTEXT_SIZE=8192
LLM_TEMPERATURE=0.1

# WebSearch — SearXNG (install.sh or deploy/searxng/setup.sh)
SEARXNG_BASE_URL=http://127.0.0.1:8888
SEARXNG_LANGUAGE=pl

# Runtime paths
DATA_DIR=./data
BUN_PATH=
REPO_ROOT=.

# CV output: HTML template → PDF via Playwright/Chromium
CV_RENDERER=html

# API server
HOST=0.0.0.0
PORT=8080
